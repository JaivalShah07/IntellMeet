PORT=5000
NODE_ENV=development

# EASIEST: leave MONGODB_URI empty and set USE_MEMORY_DB=true (no MongoDB install)
USE_MEMORY_DB=true

# OR use local MongoDB after installing (see docs/MONGODB_SETUP.md)
# USE_MEMORY_DB=false
# MONGODB_URI=mongodb://127.0.0.1:27017/intellmeet

JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173
